# Variables de entorno para Stagehand con Google Gemini y Groq

# Google Gemini
GEMINI_BASE_URL=https://api.google.com/gemini
GEMINI_API_KEY=GOOGLE_API_KEY=your_google_api_key
GEMINI_MODEL=gemini-1.5

# Groq
GROQ_BASE_URL=https://api.groq.com
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=groq-1.0

# Configuración general
HEADLESS=true
